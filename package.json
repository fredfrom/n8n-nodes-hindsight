{
	"name": "n8n-nodes-hindsight",
	"version": "0.1.3",
	"description": "n8n community node for Hindsight AI memory API by Vectorize.io",
	"license": "MIT",
	"homepage": "https://github.com/fredfrom/n8n-nodes-hindsight",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Friedemann Frommelt",
		"email": "friedemannfrommelt1996@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/fredfrom/n8n-nodes-hindsight.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist",
		"examples"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/HindsightApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Hindsight/Hindsight.node.js",
			"dist/nodes/HindsightMemory/HindsightMemory.node.js"
		]
	},
	"devDependencies": {
		"@n8n/ai-node-sdk": "*",
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"@n8n/ai-node-sdk": "*",
		"n8n-workflow": "*"
	}
}
